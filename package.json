{
  "name": "1factory-mcp",
  "version": "0.2.0-beta.1",
  "description": "Unofficial, security-focused MCP server for the 1Factory API",
  "type": "module",
  "license": "MIT",
  "author": "1Factory MCP contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trillx/1factory-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Trillx/1factory-mcp/issues"
  },
  "homepage": "https://github.com/Trillx/1factory-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "1factory-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "dev": "tsx src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "^4.1.10"
  }
}

# Use the 1Factory sandbox until the integration has been validated.
ONEFACTORY_BASE_URL=https://www.1factory.co/api/v1

# Obtain these values from the API section of your 1Factory Settings page.
# Never commit real values.
ONEFACTORY_ORG_ID=
ONEFACTORY_API_KEY=

# Write tools are not part of the initial release and must remain disabled.
ONEFACTORY_ENABLE_WRITES=false

# Requests fail closed after this duration. Allowed range: 1000–60000 ms.
ONEFACTORY_REQUEST_TIMEOUT_MS=15000

# Application behavior
LOG_LEVEL=info
MCP_TRANSPORT=stdio
